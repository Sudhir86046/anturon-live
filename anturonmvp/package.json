{
  "name": "voice-ai-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Voice AI SaaS Platform for Middle East & India",
  "scripts": {
    "build": "turbo run build --filter=@voice-ai/web...",
    "start": "cd apps/web && node_modules/.bin/next start -p 8080",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
