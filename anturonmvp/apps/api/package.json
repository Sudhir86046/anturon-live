{
  "name": "@voice-ai/api",
  "version": "1.0.0",
  "private": true,
  "exports": {
    "./router": {
      "types": "./src/trpc/router.ts",
      "import": "./dist/trpc/router.js"
    },
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "npx ts-node --skipLibCheck --transpile-only src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.3.0",
    "@supabase/supabase-js": "^2.106.1",
    "@trpc/server": "^11.0.0-rc.364",
    "@voice-ai/database": "workspace:*",
    "@voice-ai/shared": "workspace:*",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.40.0",
    "resend": "^3.2.0",
    "socket.io": "^4.7.5",
    "superjson": "^2.2.1",
    "twilio": "^5.0.4",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5"
  }
}
