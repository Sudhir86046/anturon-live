generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  industry  String?
  region    String?
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  users  User[]
  agents Agent[]
}

model User {
  id                String   @id
  organizationId    String
  name              String
  email             String   @unique
  passwordHash      String
  role              String   @default("admin")
  phoneNumber       String?
  isActive          Boolean  @default(true)
  emailVerified     Boolean  @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())

  organization       Organization        @relation(fields: [organizationId], references: [id])
  verificationTokens VerificationToken[]
}

model VerificationToken {
  id        String   @id
  userId    String
  token     String   @unique
  type      String   @default("email_verification")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Agent {
  id             String   @id
  organizationId String?
  name           String
  systemPrompt   String
  language       String   @default("en")
  sttProvider    String   @default("deepgram")
  llmProvider    String   @default("sarvam")
  ttsProvider    String   @default("deepgram")
  createdAt      DateTime @default(now())

  organization     Organization?     @relation(fields: [organizationId], references: [id])
  calls            Call[]
  knowledge        Knowledge[]
  campaigns        Campaign[]
  telephonyConfigs TelephonyConfig[]
}

model KnowledgeChunk {
  id          String   @id
  knowledgeId String
  agentId     String
  content     String
  chunkIndex  Int
  createdAt   DateTime @default(now())
}

model Call {
  id           String   @id @default(cuid())
  callId       String
  callerNumber String?
  agentId      String?
  status       String
  inputAudio   String?
  transcript   String?
  responseText String?
  outputAudio  String?
  startedAt    DateTime
  endedAt      DateTime?

  agent Agent? @relation(fields: [agentId], references: [id])
}

model Conversation {
  id          String   @id @default(cuid())
  inputAudio  String?
  transcript  String?
  llmResponse String?
  outputAudio String?
  createdAt   DateTime @default(now())
}

model Knowledge {
  id        String   @id
  agentId   String
  fileName  String
  filePath  String
  textPath  String
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])
}

model Campaign {
  id             String   @id
  name           String
  agentId        String
  csvPath        String
  totalContacts  Int
  completedCalls Int      @default(0)
  failedCalls    Int      @default(0)
  status         String
  leads          Json
  createdAt      DateTime @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  agent Agent @relation(fields: [agentId], references: [id])
}

model KnowledgeQuery {
  id        String   @id
  agentId   String
  question  String
  context   String?
  answer    String?
  createdAt DateTime @default(now())
}

model TelephonyConfig {
  id          String   @id
  agentId     String
  provider    String
  accountSid  String?
  authToken   String?
  phoneNumber String?
  sipUsername String?
  sipPassword String?
  sipDomain   String?
  status      String   @default("inactive")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
}